NODE_ENV=development
PORT=3000

# Database (Prisma / PostgreSQL)
# Apunta al servicio de Postgres expuesto por docker-compose en el host.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobiletestapp?schema=public

# Docker Compose - contenedor de Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mobiletestapp
POSTGRES_PORT=5432

# Wompi Sandbox (se configura en Fase 3 - Integracion de pagos)
# WOMPI_PUBLIC_KEY=
# WOMPI_PRIVATE_KEY=
# WOMPI_EVENTS_KEY=
# WOMPI_INTEGRITY_KEY=
# WOMPI_BASE_URL=https://sandbox.wompi.co/v1
